# Spectral — API Patterns

## Route Handler Standard Structure

```ts
// app/api/platforms/route.ts
import { NextResponse } from 'next/server'
import { createClient } from '@/lib/supabase/server'

export async function GET(request: Request) {
  try {
    // 1. Auth check (all mutation routes, recommended for read routes)
    const supabase = await createClient()
    const { data: { user } } = await supabase.auth.getUser()
    if (!user) {
      return NextResponse.json({ error: 'Unauthorised' }, { status: 401 })
    }

    // 2. Parse params
    const { searchParams } = new URL(request.url)
    const page = parseInt(searchParams.get('page') ?? '1')
    const limit = parseInt(searchParams.get('limit') ?? '50')
    const from = (page - 1) * limit
    const to = from + limit - 1

    // 3. Query
    const { data, error, count } = await supabase
      .from('platforms')
      .select('*', { count: 'exact' })
      .range(from, to)
      .order('name')

    if (error) throw error

    // 4. Return standard shape
    return NextResponse.json({
      data,
      meta: { page, limit, total: count ?? 0 }
    })
  } catch (error) {
    console.error('[GET /api/platforms]', error)
    return NextResponse.json(
      { error: 'Internal server error' },
      { status: 500 }
    )
  }
}
```

## Standard Response Shapes

### Success (list)
```json
{
  "data": [...],
  "meta": {
    "page": 1,
    "limit": 50,
    "total": 247
  }
}
```

### Success (single)
```json
{
  "data": { ... }
}
```

### Error
```json
{
  "error": "Human-readable error message"
}
```

Never return Supabase error objects directly — they leak internal schema information.

## Pagination Standard

- Default page size: 50
- Maximum page size: 100 (enforce server-side — reject >100)
- Always return `meta.total` so clients can compute page count
- Use Supabase `.range(from, to)` with exact count

```ts
const MAX_LIMIT = 100
const limit = Math.min(parseInt(searchParams.get('limit') ?? '50'), MAX_LIMIT)
```

## Server Actions Pattern

```ts
// app/(modules)/library/actions.ts
'use server'
import { createClient } from '@/lib/supabase/server'
import { revalidatePath } from 'next/cache'

export async function addPlatform(formData: FormData) {
  const supabase = await createClient()
  const { data: { user } } = await supabase.auth.getUser()
  if (!user) throw new Error('Unauthorised')

  const name = formData.get('name') as string
  // Validate
  if (!name || name.length < 2) throw new Error('Platform name required')

  const { error } = await supabase.from('platforms').insert({ name, created_by: user.id })
  if (error) throw error

  revalidatePath('/library')
}
```

## Audit Logging (all write operations)

```ts
// After any INSERT / UPDATE / DELETE on core tables
await supabase.from('audit_log').insert({
  user_id: user.id,
  action: 'INSERT',
  resource_type: 'platform',
  resource_id: data.id,
  timestamp: new Date().toISOString(),
})
```

## Input Validation Rules

| Field type | Validation |
|---|---|
| Frequency (MHz) | Positive number, 1–100,000 MHz |
| Range (km) | Positive integer, 0–20,000 |
| Text fields | Trim whitespace, max 500 chars, strip HTML |
| Enum fields | Validate against allowed values list |
| Coordinates | Lat -90 to 90, Lon -180 to 180 |

```ts
function validateFrequency(val: unknown): number {
  const n = Number(val)
  if (!isFinite(n) || n < 1 || n > 100_000) {
    throw new Error('Frequency must be between 1 and 100,000 MHz')
  }
  return n
}
```

## Service Role Key Usage

Only in server-side code that needs to bypass RLS (admin operations, seed scripts):

```ts
// lib/supabase/admin.ts — NEVER import this from client components
import { createClient } from '@supabase/supabase-js'

export function createAdminClient() {
  return createClient(
    process.env.NEXT_PUBLIC_SUPABASE_URL!,
    process.env.SUPABASE_SERVICE_ROLE_KEY!,  // server-only
  )
}
```

## Rate Limiting

Wrap AI route handlers (anything calling `querySpectral()`) with a simple rate limiter:

```ts
// app/api/ai/analyze/route.ts
const rateLimits = new Map<string, number>()

export async function POST(request: Request) {
  const { data: { user } } = await (await createClient()).auth.getUser()
  if (!user) return NextResponse.json({ error: 'Unauthorised' }, { status: 401 })

  const now = Date.now()
  const last = rateLimits.get(user.id) ?? 0
  if (now - last < 5000) {  // 5 second minimum between AI calls
    return NextResponse.json({ error: 'Rate limit — wait 5 seconds' }, { status: 429 })
  }
  rateLimits.set(user.id, now)

  // ... proceed with AI call
}
```

## What Never Goes in Route Handlers

- Top-level CesiumJS imports (browser-only)
- Direct calls to Anthropic SDK (use `querySpectral()` wrapper only)
- `SUPABASE_SERVICE_ROLE_KEY` unless it's an admin-only endpoint
- Raw user input passed to SQL without validation
