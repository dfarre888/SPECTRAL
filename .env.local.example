# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic (Claude API)
ANTHROPIC_API_KEY=sk-ant-...
# SPECTRAL-REF narrative model (default: claude-sonnet-4-6)
# SPECTRAL_REF_MODEL=claude-sonnet-4-6

# PCM adjudication — set true to use placeholder stub instead of training core
# SPECTRAL_PCM_STUB_ADJUDICATION=false

# Cesium Ion (terrain + imagery tiles)
NEXT_PUBLIC_CESIUM_ION_TOKEN=your-cesium-ion-token

# Windy (server-only — map intel live wind mode)
WINDY_API_KEY=your-windy-api-key

# Edition: training (default) | operations (server propagation + adjudication)
# SPECTRAL_EDITION=operations
# NEXT_PUBLIC_SPECTRAL_EDITION=operations

# OIDC SSO (Operations tenants — Keycloak / Azure AD)
# SPECTRAL_OIDC_ENABLED=true
# SPECTRAL_OIDC_ISSUER=https://idp.example.com/realms/spectral
# SPECTRAL_OIDC_CLIENT_ID=spectral-web
# SPECTRAL_OIDC_CLIENT_SECRET=server-only-secret
# NEXT_PUBLIC_SPECTRAL_OIDC_ENABLED=true
# NEXT_PUBLIC_SPECTRAL_OIDC_ISSUER=https://idp.example.com/realms/spectral
# NEXT_PUBLIC_SPECTRAL_OIDC_CLIENT_ID=spectral-web

# Cesium static asset base (optional override)
# Training/Vercel: /_next/static/Cesium  |  Helm/air-gap: /static/Cesium
NEXT_PUBLIC_CESIUM_BASE_URL=/_next/static/Cesium

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_ENV=development

# Demo mode — bypass auth + use service-role reads (local training only; never in production)
NEXT_PUBLIC_DEMO_MODE=true
