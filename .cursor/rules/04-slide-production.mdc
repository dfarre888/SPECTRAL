## img16x9() Helper
```js
// phase7/_master/img16x9.js
// Returns a pptxgenjs image object ready to drop as a full-bleed background
// with optional dark overlay for text legibility

function img16x9(pptx, slide, imgPath, { overlayOpacity = 0.5, overlayColor = '000000' } = {}) {
  // Full-bleed image
  slide.addImage({ path: imgPath, x: 0, y: 0, w: '100%', h: '100%' })
  // Dark overlay
  if (overlayOpacity > 0) {
    slide.addShape(pptx.ShapeType.rect, {
      x: 0, y: 0, w: '100%', h: '100%',
      fill: { color: overlayColor, transparency: Math.round((1 - overlayOpacity) * 100) },
      line: { color: overlayColor, transparency: 100 },
    })
  }
}

module.exports = { img16x9 }
```

## Classification Banner (mandatory, every slide)
```js
// Add to EVERY slide — no exceptions
function addClassifBanner(slide, BRAND, FONT, CLASSIF_TEXT) {
  slide.addText(CLASSIF_TEXT, {
    x: 0.3, y: 5.35, w: 9.4, h: 0.2,
    fontFace: FONT.classif,
    fontSize: 8,
    color: BRAND.textSecondary,
    align: 'left',
    valign: 'middle',
  })
}
```

## Slide Layout Patterns

### COVER slide
```js
// Full-bleed Higgsfield image + overlay + logo + title + classif
function buildCover(pptx, slide, { imgPath, title, subtitle }) {
  const { BRAND, FONT, CLASSIF_TEXT } = require('./_master/BUILD_CONSTANTS')
  const { img16x9 } = require('./_master/img16x9')

  img16x9(pptx, slide, imgPath, { overlayOpacity: 0.65 })

  // Logo placeholder (top-left)
  slide.addText('SPECTRAL PCM', {
    x: 0.4, y: 0.3, w: 3, h: 0.4,
    fontFace: FONT.display, fontSize: 14,
    color: BRAND.orange, bold: true,
  })

  // Main title (centre, lower third)
  slide.addText(title, {
    x: 0.5, y: 2.8, w: 9, h: 1.2,
    fontFace: FONT.display, fontSize: 48,
    color: BRAND.textPrimary, bold: true,
    align: 'center',
  })

  if (subtitle) {
    slide.addText(subtitle, {
      x: 0.5, y: 4.1, w: 9, h: 0.5,
      fontFace: FONT.body, fontSize: 18,
      color: BRAND.textSecondary, align: 'center',
    })
  }

  addClassifBanner(slide, BRAND, FONT, CLASSIF_TEXT)
}
```

### SECTION DIVIDER slide
```js
function buildSectionDivider(pptx, slide, { dayNum, dayTitle, subtitle }) {
  // Solid orange left panel (40% width)
  slide.addShape(pptx.ShapeType.rect, {
    x: 0, y: 0, w: '40%', h: '100%',
    fill: { color: BRAND.orange },
    line: { color: BRAND.orange },
  })
  // Day number
  slide.addText(`DAY ${dayNum}`, {
    x: 0.3, y: 1.8, w: 3.7, h: 1.2,
    fontFace: FONT.display, fontSize: 72,
    color: BRAND.bg, bold: true, align: 'center',
  })
  // Title right panel
  slide.addShape(pptx.ShapeType.rect, {
    x: '40%', y: 0, w: '60%', h: '100%',
    fill: { color: BRAND.bg },
    line: { color: BRAND.bg },
  })
  slide.addText(dayTitle, {
    x: 4.2, y: 1.5, w: 5.5, h: 1.5,
    fontFace: FONT.display, fontSize: 32,
    color: BRAND.textPrimary, bold: true,
  })
  if (subtitle) {
    slide.addText(subtitle, {
      x: 4.2, y: 3.1, w: 5.5, h: 0.8,
      fontFace: FONT.body, fontSize: 16,
      color: BRAND.textSecondary,
    })
  }
  addClassifBanner(slide, BRAND, FONT, CLASSIF_TEXT)
}
```

### LEARNING OBJECTIVES slide
```js
function buildLOs(pptx, slide, { lessonTitle, los, assessmentType }) {
  // Header bar
  slide.addShape(pptx.ShapeType.rect, {
    x: 0, y: 0, w: '100%', h: 0.7,
    fill: { color: BRAND.orange }, line: { color: BRAND.orange },
  })
  slide.addText('LEARNING OBJECTIVES', {
    x: 0.3, y: 0, w: 9.4, h: 0.7,
    fontFace: FONT.header, fontSize: 18, bold: true,
    color: BRAND.bg, valign: 'middle',
  })
  slide.addText(`By the end of this lesson you will be able to:`, {
    x: 0.5, y: 0.85, w: 9, h: 0.35,
    fontFace: FONT.body, fontSize: 14, color: BRAND.textSecondary,
  })
  // LO items
  los.forEach((lo, i) => {
    slide.addText(`LO${i + 1}  —  ${lo}`, {
      x: 0.5, y: 1.3 + i * 0.65, w: 9, h: 0.55,
      fontFace: FONT.body, fontSize: 15, color: BRAND.textPrimary,
    })
  })
  // Assessment line
  slide.addText(`ASSESSMENT:  ${assessmentType}`, {
    x: 0.5, y: 4.7, w: 9, h: 0.35,
    fontFace: FONT.classif, fontSize: 11,
    color: BRAND.cyan, bold: true,
  })
  addClassifBanner(slide, BRAND, FONT, CLASSIF_TEXT)
}
```

### CONTENT slide (two-column)
```js
function buildTwoColumn(pptx, slide, { title, leftContent, rightImgPath }) {
  // Title
  slide.addText(title, {
    x: 0.4, y: 0.2, w: 9.2, h: 0.6,
    fontFace: FONT.header, fontSize: 24, bold: true,
    color: BRAND.textPrimary,
  })
  // Divider line
  slide.addShape(pptx.ShapeType.line, {
    x: 0.4, y: 0.9, w: 9.2, h: 0,
    line: { color: BRAND.divider, width: 1 },
  })
  // Left text
  slide.addText(leftContent, {
    x: 0.4, y: 1.0, w: 4.6, h: 4.0,
    fontFace: FONT.body, fontSize: 14,
    color: BRAND.textPrimary, valign: 'top',
  })
  // Right image
  if (rightImgPath) {
    slide.addImage({ path: rightImgPath, x: 5.2, y: 1.0, w: 4.5, h: 3.8 })
  }
  addClassifBanner(slide, BRAND, FONT, CLASSIF_TEXT)
}
```

