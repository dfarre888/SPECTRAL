```js
// Large number + label — for spine facts and data emphasis
function buildKeyStat(pptx, slide, { stat, label, context, accentColor }) {
  const color = accentColor || BRAND.orange
  slide.addText(stat, {
    x: 0.5, y: 0.8, w: 9, h: 2.5,
    fontFace: FONT.display, fontSize: 96, bold: true,
